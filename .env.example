# Copy to .env and fill in your Supabase project credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: Postgres connection string for permanent data storage (e.g. your
# Supabase project's own database — Settings > Database > Connection string > URI).
# If left unset, the app falls back to a local SQLite file at data/katorifit.db,
# which is fine for local development but resets on redeploy on hosts with
# ephemeral filesystems (e.g. free-tier Streamlit Community Cloud).
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres
